# ╔═══════════════════════════════════════════════════════════════════╗
# ║              SkillHub Backend Environment Variables                ║
# ║                                                                   ║
# ║ Copy this file to .env and update with your actual values         ║
# ╚═══════════════════════════════════════════════════════════════════╝

# ── Database Configuration ──────────────────────────────────────────
# MongoDB connection string
# Local: mongodb://localhost:27017/skillhub
# Cloud (MongoDB Atlas): mongodb+srv://username:password@cluster.mongodb.net/skillhub?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://your_username:your_password@your_cluster.mongodb.net/skillhub?retryWrites=true&w=majority

# ── Server Configuration ────────────────────────────────────────────
# Server port (default: 5000)
PORT=5000

# ── JWT Configuration ──────────────────────────────────────────────
# Secret key for JWT signing (use a strong random string)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# JWT expiration time (examples: 7d, 24h, 30d)
JWT_EXPIRE=7d

# ── CORS Configuration ─────────────────────────────────────────────
# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# ── Email Configuration (Optional - for future use) ────────────────
# EMAIL_SERVICE=gmail
# EMAIL_USER=your_email@gmail.com
# EMAIL_PASS=your_app_password

# ── Node Environment ──────────────────────────────────────────────
NODE_ENV=production
